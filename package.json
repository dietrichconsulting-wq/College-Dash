{
  "name": "college-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "cd client && npm run dev -- --host",
    "dev:server": "cd server && npx nodemon index.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "cd client && npm run build",
    "start": "cd server && node index.js",
    "setup:supabase": "echo 'Run tools/supabase-migration.sql in the Supabase SQL Editor'",
    "validate": "node tools/validate-env.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "dotenv": "^17.3.1"
  }
}
